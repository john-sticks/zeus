@{
    ViewData["Title"] = "Consulta Hechos";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
<link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/css/tom-select.css" rel="stylesheet" />
<style>
    #mapaFiltro {
        border-radius: 6px;
        border: 1px solid #ddd;
    }

    #mapa {
        height: 400px;
        width: 100%;
        min-height: 300px;
    }
</style>
<div class="content">
    <div class="box">
        <div class="box-header with-border">
            <h3 class="box-title">Filtro</h3>

            <div class="box-tools pull-right">
                <button type="button" class="btn btn-box-tool" data-widget="collapse">
                    <i class="fa fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="box-body">
            <div class="form-horizontal">

                <!-- IPP -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">IPP</label>

                    <div class="col-sm-6">
                        <input type="text" id="ipp" class="form-control" placeholder="Ingrese IPP" />
                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enableIPP"> Activar
                        </label>
                    </div>
                </div>

                <!-- FECHAS -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">Rango de fechas</label>

                    <div class="col-sm-6">

                        <div class="input-group">
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                            <input type="text" id="rangoFechas" class="form-control" />
                        </div>

                        <div style="margin-top:8px;">
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2021)">2021</button>
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2022)">2022</button>
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2023)">2023</button>
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2024)">2024</button>
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2025)">2025</button>
                            <button type="button" class="btn btn-xs btn-default" onclick="setYear(2026)">2026</button>
                        </div>

                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enableFechas"> Activar
                        </label>
                    </div>
                </div>

                <!-- PARTIDO -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">Partido</label>

                    <div class="col-sm-6">
                        <select id="partido" multiple></select>
                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enablePartido"> Activar
                        </label>
                    </div>
                </div>

                <!-- CALIFICACION -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">Calificación</label>

                    <div class="col-sm-6">
                        <select id="calificaciones" multiple></select>
                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enableCalificaciones"> Activar
                        </label>
                    </div>
                </div>

                <!-- DOMICILIO -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">Domicilio</label>

                    <div class="col-sm-2">
                        <input type="text" id="calle" class="form-control" placeholder="Calle" />
                    </div>

                    <div class="col-sm-2">
                        <input type="text" id="altura" class="form-control" placeholder="Altura" />
                    </div>

                    <div class="col-sm-2">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="alturaAprox"> Altura aprox
                        </label>
                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enableDomicilio"> Activar
                        </label>
                    </div>
                </div>

                <!-- RELATO -->
                <div class="form-group">
                    <label class="col-sm-3 control-label">En cuerpo del relato</label>

                    <div class="col-sm-6">
                        <textarea id="relato" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-sm-3">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="enableRelato"> Activar
                        </label>
                    </div>
                </div>
                <div class="form-group">
                    <label class="col-sm-3 control-label">
                        Cantidad de Resultados
                    </label>

                    <div class="col-sm-6">
                        <select id="cantidad" class="form-control">
                            <option value="50">50</option>
                            <option value="100">100</option>
                            <option value="150">150</option>
                            <option value="200">200</option>
                            <option value="250">250</option>
                            <option value="500">500</option>
                            <option value="1000">1000</option>
                        </select>
                    </div>

                    <div class="col-sm-3"></div>
                </div>

                @* <div class="form-group">
                    <div class="col-sm-offset-3 col-sm-9">

                        <button type="button" class="btn btn-default" id="btnBuscar">
                            Buscar
                        </button>

                        <button class="btn btn-default" onclick="limpiar()">
                            Limpiar
                        </button>

                    </div>
                </div> *@
            </div>
        </div>

    

        <div class="box box-default collapsed-box" id="boxGeo">

            <div class="box-header with-border">
                <h3 class="box-title">Búsqueda geográfica</h3>

                <div class="box-tools pull-right">
                    <button type="button" class="btn btn-box-tool" data-widget="collapse">
                        <i class="fa fa-plus"></i>
                    </button>
                </div>
            </div>

            <div class="box-body">

                <div class="form-horizontal">

                    <div class="form-group">

                        <!-- LABEL -->
                        <label class="col-sm-3 control-label">
                            A partir de una ubicación en el mapa
                        </label>

                        <!-- CENTRO -->
                        <div class="col-sm-6">

                            <!-- BOTON -->
                            <button type="button"
                                    class="btn btn-default mb-2"
                                    onclick="usarUbicacionActual()">
                                Obtener mi Ubicación Actual Aproximada
                            </button>

                            <!-- MAPA -->
                            <div id="mapaFiltro" style="height:400px;"></div>

                            <!-- RADIO -->
                            <input type="number"
                                    id="radio"
                                    class="form-control mt-2"
                                    placeholder="Ingresar un radio de búsqueda (en metros) Ej 500" />

                        </div>

                        <!-- CHECKBOX -->
                        <div class="col-sm-3">
                            <label class="checkbox-inline">
                                <input type="checkbox" id="enableGeo" />
                                Activar búsqueda geográfica
                            </label>
                        </div>

                    </div>

                </div>

            </div>
        </div>
   
        <div class="box-body">

            <div class="form-horizontal">
                <div class="form-group">
                    <div class="col-sm-offset-3 col-sm-9">

                        <button type="button" class="btn btn-default" id="btnBuscar">
                            Buscar
                        </button>

                        <button class="btn btn-default" onclick="limpiar()">
                            Limpiar
                        </button>

                    </div>
                </div>
    
             </div>  
         </div>
    </div>
    <!-- RESULTADOS -->
    <div id="boxResultados" style="display:none;">
        <button class="btn btn-success" onclick="irAInforme()">
            Crear informe con seleccionados
        </button>
        <!-- TABLA -->
        <div class="card p-3">
            <h4>Resultados</h4>
            <table class="table table-sm table-bordered" id="tabla">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="chkAll"></th>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Partido</th>
                        <th>Localidad</th>
                        <th>Calificación</th>
                        <td>Dependencia</td>
                    </tr>
                    <tr id="filaFiltros">

                        <th></th> <!-- checkbox -->

                        <th></th> <!-- ID (sin filtro por ahora) -->

                        <th>
                           
                        </th>

                        <th>
                            <select id="filtroPartido" class="form-control input-sm"></select>
                        </th>

                        <th>
                            <select id="filtroLocalidad" class="form-control input-sm"></select>
                        </th>

                        <th>
                            <select id="filtroCalificacion" class="form-control input-sm"></select>
                        </th>

                        <th>
                            <select id="filtroDependencia" class="form-control input-sm"></select>
                        </th>
                       
                        
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
            <div id="paginador" style="margin-top:10px;"></div>
        </div>
        
        <!-- MODOS MAPA -->
        <div class="mb-2">
            <button id="btnCluster" class="btn btn-sm btn-primary btn-modo-mapa" onclick="setModoMapa('cluster')">Cluster</button>
            <button id="btnPuntos" class="btn btn-sm btn-default btn-modo-mapa" onclick="setModoMapa('puntos')">Puntos</button>
            <button id="btnCalor" class="btn btn-sm btn-default btn-modo-mapa" onclick="setModoMapa('calor')">Heatmap</button>
        </div>

        <!-- MAPA -->
        <div id="boxMapaResultados" class="card p-3 mt-3" style="display:none;">
            <h4>Mapa</h4>
            <div id="mapa" style="height:400px;"></div>
            <div id="leyendaMapa" class="mt-2"></div>
        </div>

    </div>

</div>
@section Scripts {

    <script src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>

    <script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
    <script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.3/dist/js/tom-select.complete.min.js"></script>
    <script src="~/js/hechos-consulta.js" asp-append-version="true"></script>
}
